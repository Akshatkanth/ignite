# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ─────────────────────────────────────────────────────────────────
# Local Docker: postgresql://postgres:postgres@localhost:5432/devflow
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/devflow

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local Docker: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ─── JWT Secrets (generate with: openssl rand -hex 32) ────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
JWT_ACCESS_SECRET=change_me_generate_with_openssl_rand_hex_32_at_least_32_chars
JWT_REFRESH_SECRET=change_me_another_secret_generate_with_openssl_rand_hex_32

# ─── JWT Expiry ───────────────────────────────────────────────────────────────
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Worker Toggle ───────────────────────────────────────────────────────────
ENABLE_DEPLOYMENT_WORKER=true

# ─── Frontend API URL (used by Netlify build/runtime) ────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
